# FOROL Futur Integration
# Wird in Vercel Dashboard unter Settings > Environment Variables gesetzt

# URL des FOROL Futur Import-Endpoints
FOROL_FUTUR_API_URL=https://rechnungen.forol.ch/api/import/kostenvoranschlag

# API Key für FOROL Futur (wird im Authorization: Bearer Header mitgeschickt)
FOROL_FUTUR_API_KEY=your-api-key-here

# Anthropic API Key (für KI-Plananalyse, wird vom Client direkt verwendet)
# WICHTIG: Niemals in .env.local – wird nur im Vercel Dashboard gesetzt
ANTHROPIC_API_KEY=your-anthropic-key-here
